<div class="fr-grid-row">
  <div class="fr-col-12 fr-col-md-4">
    <%= dsfr_side_menu(title: t(".checks_documentation_title"), html_attributes: { class: "fr-sidemenu--sticky" }) do |sidemenu| %>
      <% @check_pages.each do |page| %>
        <% sidemenu.with_item title: page[:title], path: help_check_path(page[:file_name]), current_page: @check == page[:file_name] %>
      <% end %>
    <% end %>
  </div>

  <div class="fr-col-12 fr-col-md-8">
    <% if @check %>
      <%= render template: "pages/checks/#{@check}" %>
    <% else %>
      <h3><%= t(".need_help_title") %></h3>
      <p><%= t(".need_help_description") %></p>
    <% end %>
  </div>
</div>
